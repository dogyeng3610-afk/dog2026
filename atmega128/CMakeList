cmake_minimum_required(VERSION 3.10)

# standalone configureмқј л•Ңл§Ң кё°ліё AVR нҲҙмІҙмқё нҢҢмқјмқ„ м§Җм •н•ңлӢӨ.
if(CMAKE_SOURCE_DIR STREQUAL CMAKE_CURRENT_SOURCE_DIR AND NOT DEFINED CMAKE_TOOLCHAIN_FILE)
    set(CMAKE_TOOLCHAIN_FILE "${CMAKE_CURRENT_SOURCE_DIR}/avr-toolchain.cmake")
endif()

project(Atmega128_Project C)

# --- н•ҳл“ңмӣЁм–ҙ м„Өм • ---
set(MCU atmega128)
set(F_CPU 16000000UL)
set(PROG_TYPE stk500v2)
set(PROG_PORT usb)

# --- uart2 мӢӨн–ү нҢҢмқј л°Ҹ мҳөм…ҳ ---
# uart2лҠ” uart0 лқјмқҙлёҢлҹ¬лҰ¬лҘј мӮ¬мҡ©н•ҳлҜҖлЎң uart0 мҶҢмҠӨлҸ„ к°ҷмқҙ л§ҒнҒ¬н•©лӢҲлӢӨ.
add_executable(${PROJECT_NAME}.elf lib/lcd/lcd.c src/lcd1.c)

target_include_directories(${PROJECT_NAME}.elf PRIVATE ${CMAKE_CURRENT_SOURCE_DIR}/lib/lcd)

target_compile_options(${PROJECT_NAME}.elf PUBLIC
    -mmcu=${MCU}
    -DF_CPU=${F_CPU}
    -Os -Wall
)

target_link_options(${PROJECT_NAME}.elf PUBLIC -mmcu=${MCU})

# --- lcd1 мӢӨн–ү нҢҢмқј л°Ҹ мҳөм…ҳ ---
add_executable(lcd1.elf src/lcd1.c lib/lcd/lcd.c)

target_include_directories(lcd1.elf PRIVATE ${CMAKE_CURRENT_SOURCE_DIR}/lib/lcd)

target_compile_options(lcd1.elf PUBLIC
    -mmcu=${MCU}
    -DF_CPU=${F_CPU}
    -Os -Wall
)

target_link_options(lcd1.elf PUBLIC -mmcu=${MCU})

# --- uart2 л№Ңл“ң нӣ„мІҳлҰ¬ (HEX мғқм„ұ) ---
add_custom_command(TARGET ${PROJECT_NAME}.elf POST_BUILD
    COMMAND avr-objcopy -j .text -j .data -O ihex ${PROJECT_NAME}.elf ${PROJECT_NAME}.hex
    COMMAND avr-size --format=avr --mcu=${MCU} ${PROJECT_NAME}.elf
    COMMENT "Generating Intel HEX file and analysis"
)

# --- lcd1 л№Ңл“ң нӣ„мІҳлҰ¬ (HEX мғқм„ұ) ---
add_custom_command(TARGET lcd1.elf POST_BUILD
    COMMAND avr-objcopy -j .text -j .data -O ihex lcd1.elf lcd1.hex
    COMMAND avr-size --format=avr --mcu=${MCU} lcd1.elf
    COMMENT "Generating Intel HEX file and analysis"
)

# --- м—…лЎңл“ң нғҖкІҹ м¶”к°Җ ---
add_custom_target(upload_uart2
    COMMAND avrdude -p m128 -c ${PROG_TYPE} -P ${PROG_PORT} -U flash:w:${PROJECT_NAME}.hex:i
    DEPENDS ${PROJECT_NAME}.elf
    COMMENT "Flashing ${PROJECT_NAME}.hex to hardware..."
)

add_custom_target(upload_lcd1
    COMMAND avrdude -p m128 -c ${PROG_TYPE} -P ${PROG_PORT} -U flash:w:lcd1.hex:i
    DEPENDS lcd1.elf
    COMMENT "Flashing lcd1.hex to hardware..."
)

